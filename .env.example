# Postgres connection string (Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# SerpAPI key for Google Shopping discovery (https://serpapi.com)
SERPAPI_API_KEY=

# Resend API key for sending alert emails (https://resend.com)
RESEND_API_KEY=

# Where alert digest emails are sent
ALERT_EMAIL_TO=you@example.com

# Verified sender address/name in Resend
ALERT_EMAIL_FROM="Price Tracker <alerts@yourdomain.com>"

# Shared secret to protect the cron endpoint; Vercel Cron sends this automatically
# as a Bearer token when set as the CRON_SECRET project env var.
CRON_SECRET=
